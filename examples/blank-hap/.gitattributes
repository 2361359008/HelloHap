# Normalize line endings across platforms.
# Shell scripts must always be LF, otherwise OpenHarmony's /system/bin/sh
# treats the trailing CR as part of the command/argument (e.g. `set -eu\r`).
*.sh        text eol=lf

# Windows-only scripts need CRLF.
*.ps1       text eol=crlf
*.bat       text eol=crlf
*.cmd       text eol=crlf

# Treat common source/text files as text with normalized (LF) endings.
*.ets       text eol=lf
*.ts        text eol=lf
*.js        text eol=lf
*.json      text eol=lf
*.json5     text eol=lf
*.md        text eol=lf

# Binary assets — never touch.
*.png       binary
*.jpg       binary
*.jpeg      binary
*.p12       binary
*.hap       binary
*.har       binary
*.hsp       binary
